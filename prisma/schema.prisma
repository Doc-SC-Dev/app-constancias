generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AcademicDegree {
  id        String          @id @default(uuid())
  name      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  title     AcademicTitle[]
  users     User[]

  @@map("academic_degree")
}

model AcademicTitle {
  id               String         @id @default(uuid())
  academicDegreeId String
  gender           Gender
  abbrev           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  degree           AcademicDegree @relation(fields: [academicDegreeId], references: [id], onDelete: Cascade)

  @@map("academic_title")
}

model User {
  id               String          @id
  rut              String          @unique
  name             String
  email            String          @unique
  emailVerified    Boolean         @default(false)
  image            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt
  role             Role            @default(STUDENT)
  banned           Boolean         @default(false)
  banReason        String?
  banExpires       DateTime?
  gender           Gender
  isDirector       Boolean         @default(false)
  academicDegreeId String?
  accounts         Account[]
  logs             Log[]
  otherRequests    OtherRequest[]
  participants     Participant[]
  requests         Request[]
  sessions         Session[]
  student          Student?
  academicDegree   AcademicDegree? @relation(fields: [academicDegreeId], references: [id])

  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, providerId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Student {
  id                      String                   @id @default(uuid())
  studentId               Int                      @unique
  userId                  String                   @unique
  isRegularStudent        Boolean                  @default(false)
  admisionDate            DateTime                 @default(now())
  updatedAt               DateTime                 @default(now()) @updatedAt
  createdAt               DateTime                 @default(now())
  qualificationExamGrades QualificationExamGrade[]
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student")
}

model QualificationExamGrade {
  id         String   @id @default(uuid())
  studentId  String
  activityId String
  grade      Float
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, activityId])
  @@map("qualification_exam_grade")
}

model OtherRequest {
  id              String    @id @default(uuid())
  userId          String
  name            String
  description     String
  link            String?
  rejectionReason String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests        Request[]

  @@map("other_request")
}

model ActivityType {
  id               String                @id @default(uuid())
  name             String                @unique
  participantTypes ParticipantType[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @default(now()) @updatedAt
  activities       Activity[]
  template         CertificateTemplate[]

  @@map("activity_type")
}

model Activity {
  id                      String                   @id @default(uuid())
  activityTypeId          String
  name                    String
  startAt                 DateTime
  endAt                   DateTime?
  nAssistant              Int?
  nParticipants           Int
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @default(now()) @updatedAt
  activityType            ActivityType             @relation(fields: [activityTypeId], references: [id])
  participants            Participant[]
  qualificationExamGrades QualificationExamGrade[]
  requests                Request[]

  @@map("activity")
}

model ParticipantType {
  id             String                @id @default(uuid())
  name           String
  roles          Role[]                @default([STUDENT, PROFESSOR])
  activityType   ActivityType?         @relation(fields: [activityTypeId], references: [id])
  activityTypeId String?
  participants   Participant[]
  required       Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @default(now()) @updatedAt
  template       CertificateTemplate[]

  @@map("participant_type")
}

model Participant {
  id                String          @id @default(uuid())
  activityId        String
  userId            String
  hours             Int
  startAt           DateTime?
  endAt             DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  participantTypeId String
  activity          Activity        @relation(fields: [activityId], references: [id], onDelete: Cascade)
  type              ParticipantType @relation(fields: [participantTypeId], references: [id])
  user              User            @relation(fields: [userId], references: [id])

  @@map("participant")
}

model Certificate {
  id        String                @id @default(uuid())
  name      String                @unique
  roles     Role[]                @default([PROFESSOR, STUDENT])
  requests  Request[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now()) @updatedAt
  template  CertificateTemplate[]

  @@map("certificate")
}

model Request {
  id               String        @id @default(uuid())
  userId           String
  certificateId    String
  state            RequestState
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  activityId       String?
  otherRequestId   String?
  generatedContent String?
  activity         Activity?     @relation(fields: [activityId], references: [id])
  certificate      Certificate   @relation(fields: [certificateId], references: [id])
  otherRequest     OtherRequest? @relation(fields: [otherRequestId], references: [id])
  user             User          @relation(fields: [userId], references: [id])

  @@map("request")
}

model Log {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  userName   String
  newValue   Json
  oldValue   Json
  resourceId String
  userId     String?
  action     String
  resource   String
  user       User?    @relation(fields: [userId], references: [id])

  @@map("log")
}

model AcademicPeriod {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(true)
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  @@map("academic_period")
}

model CertificateTemplate {
  id                String   @id @default(uuid())
  certificateId     String
  role              Role?
  activityTypeId    String?
  participantTypeId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  template          String

  certificate     Certificate      @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  participantType ParticipantType? @relation(fields: [participantTypeId], references: [id], onDelete: Cascade)
  activityType    ActivityType?    @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)

  @@map("certificate_template")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  SUPERADMIN
  ADMINISTRATOR
  PROFESSOR
  STUDENT
}

enum RequestState {
  PENDING
  REJECTED
  APPROVED
  CANCELED
  READY
}
